{
  "name": "locust-ui",
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "main": "./lib/webui.js",
  "types": "./lib/types/lib.d.ts",
  "files": [
    "lib",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/locustio/locust/tree/master/locust/webui"
  },
  "scripts": {
    "dev": "vite",
    "watch": "npm-run-all --parallel watch:ui watch:report",
    "build:ui": "vite build",
    "build:lib": "vite build --config vite.lib.config.ts",
    "build:report": "vite build --config vite.report.config.ts",
    "watch:ui": "vite build --watch",
    "watch:report": "vite build --config vite.lib.config.ts --watch",
    "build": "yarn clean && npm-run-all --parallel build:ui build:report",
    "clean": "rimraf dist",
    "lint": "eslint './src/**/*.{ts,tsx}'",
    "format": "prettier --write '**/**/*.{ts,tsx}'",
    "type-check": "tsc",
    "test": "vitest --silent=false"
  },
  "peerDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.1.1",
    "@mui/material": "^7.1.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-redux": "^9.2.0"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/server": "^11.11.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@reduxjs/toolkit": "^2.12.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-redux": "^7.1.34",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "echarts": "^6.1.0",
    "npm-run-all": "^4.1.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^6.1.2",
    "react-redux": "^9.3.0",
    "rimraf": "^6.1.3",
    "terser": "^5.48.0",
    "vite": "^8.1.3",
    "vite-plugin-checker": "^0.14.4",
    "vite-plugin-dts": "^5.0.3",
    "vite-plugin-singlefile": "^2.3.3",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^10.6.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jsdom": "^29.1.1",
    "msw": "^2.15.0",
    "prettier": "^3.9.4",
    "rollup": "^4.62.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "vitest-webgl-canvas-mock": "^1.1.0"
  },
  "packageManager": "yarn@4.12.0",
  "engines": {
    "node": ">=22.12.0"
  }
}
